---
import Layout from '../layouts/Layout.astro';
import { profile, projects, experience, proof, testimonials, writing, articles } from '../data/portfolio';

const featured = projects.filter((p) => p.featured);
const others = projects.filter((p) => !p.featured);

// Floating tech-stack constellation for the hero gutters.
// x/y = % position, s = size px, d = parallax depth, dur/delay = idle float timing.
const orbits = [
  { icon: 'shopify',     x: 7,  y: 23, s: 46, d: 0.30, dur: 7.0, delay: 0.0 },
  { icon: 'react',       x: 15, y: 40, s: 40, d: 0.56, dur: 8.0, delay: 1.2 },
  { icon: 'docker',      x: 6,  y: 57, s: 44, d: 0.40, dur: 6.5, delay: 0.6 },
  { icon: 'postgresql',  x: 16, y: 73, s: 38, d: 0.64, dur: 7.5, delay: 1.8 },
  { icon: 'php',         x: 9,  y: 88, s: 42, d: 0.48, dur: 6.0, delay: 0.3 },
  { icon: 'nodejs',      x: 92, y: 22, s: 46, d: 0.32, dur: 7.2, delay: 0.9 },
  { icon: 'aws',         x: 84, y: 40, s: 52, d: 0.58, dur: 8.0, delay: 0.4 },
  { icon: 'mysql',       x: 93, y: 57, s: 42, d: 0.42, dur: 6.5, delay: 1.5 },
  { icon: 'digitalocean',x: 85, y: 73, s: 40, d: 0.62, dur: 7.5, delay: 0.7 },
  { icon: 'css',         x: 91, y: 88, s: 40, d: 0.50, dur: 6.0, delay: 1.1 },
];
---

<Layout>
  <nav class="nav">
    <div class="nav-bar">
      <a href="#top" class="logo">kazi<span class="dot">.</span>badrul</a>
      <div class="nav-links">
        <a href="#work">Work</a>
        <a href="#proof">Proof</a>
        <a href="#about">About</a>
        <a href="#experience">Experience</a>
        <a href="#writing">Writing</a>
      </div>
      <a class="nav-cta" href={`mailto:${profile.email}`}>Let's talk →</a>
    </div>
  </nav>

  <main id="top">
    <!-- HERO -->
    <header class="hero">
      <div class="hero-glow" aria-hidden="true"></div>

      <!-- floating tech-stack constellation -->
      <svg class="hero-web" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
        <polyline points="7,23 15,40 6,57 16,73 9,88" />
        <polyline points="92,22 84,40 93,57 85,73 91,88" />
      </svg>
      <div class="hero-orbits" aria-hidden="true">
        {orbits.map((o) => (
          <span
            class="orbit"
            data-depth={o.d}
            style={`--x:${o.x}%;--y:${o.y}%;--s:${o.s}px;--dur:${o.dur}s;--delay:${o.delay}s`}
          >
            <img src={`/tech/${o.icon}.svg`} alt="" loading="lazy" />
          </span>
        ))}
      </div>

      <div class="wrap">
        <div class="hero-copy">
          <span class="hero-badge" data-reveal style="--d:0ms"><span class="pulse"></span> Available for freelance &amp; full-time</span>
          <h1 data-reveal style="--d:80ms">
            I build software
            <span class="accent-text">end&#8288;-&#8288;to&#8288;-&#8288;end.</span>
          </h1>
          <p class="lede" data-reveal style="--d:180ms">
            Software Engineer — backend, frontend &amp; mobile.
          </p>
          <div class="cta-row" data-reveal style="--d:260ms">
            <a class="btn btn-primary" href="#work">View work →</a>
            <a class="btn btn-ghost" href={`mailto:${profile.email}`}>Get in touch</a>
          </div>
          <div class="hero-metrics" data-reveal style="--d:340ms">
            <span><b>400+</b> merchants served</span>
            <span class="sep">/</span>
            <span><b>4M+</b> requests / month</span>
            <span class="sep">/</span>
            <span><b>{profile.years}</b> years shipping</span>
          </div>
        </div>

        <figure class="hero-portrait" data-reveal style="--d:220ms">
          <img src={profile.portrait} alt={`Portrait of ${profile.name}`} width="900" height="748" />
        </figure>
      </div>

      <script is:inline>
        (() => {
          const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (reduce) return;
          const hero = document.querySelector('.hero');
          const copy = document.querySelector('.hero-copy');
          const portrait = document.querySelector('.hero-portrait');
          const glow = document.querySelector('.hero-glow');
          const web = document.querySelector('.hero-web');
          if (!hero) return;

          // floating icons: each drifts at its own depth
          const orbits = [...document.querySelectorAll('.orbit')].map((el) => ({
            el, depth: parseFloat(el.dataset.depth) || 0.4, cur: 0,
          }));

          // eased (lerped) scroll targets → motion trails the scroll for a silky feel
          const s = { pY: 0, gY: 0, cY: 0, cO: 1, wY: 0 };
          const t = { pY: 0, gY: 0, cY: 0, cO: 1, wY: 0 };
          let sy = 0;
          const lerp = (a, b, f) => a + (b - a) * f;

          const onScroll = () => {
            sy = window.scrollY;
            const vh = innerHeight || 1;
            t.pY = sy * 0.16;
            t.gY = sy * 0.30;
            t.cY = sy * -0.05;
            t.wY = sy * 0.45;
            t.cO = Math.max(0, 1 - sy / (vh * 0.9));
          };

          let raf = 0;
          const tick = () => {
            s.pY = lerp(s.pY, t.pY, 0.085);
            s.gY = lerp(s.gY, t.gY, 0.06);
            s.cY = lerp(s.cY, t.cY, 0.1);
            s.cO = lerp(s.cO, t.cO, 0.1);
            s.wY = lerp(s.wY, t.wY, 0.07);
            if (portrait) portrait.style.translate = '0 ' + s.pY.toFixed(2) + 'px';
            if (glow) glow.style.translate = '0 ' + s.gY.toFixed(2) + 'px';
            if (web) web.style.translate = '0 ' + s.wY.toFixed(2) + 'px';
            if (copy) { copy.style.translate = '0 ' + s.cY.toFixed(2) + 'px'; copy.style.opacity = s.cO.toFixed(3); }
            for (const o of orbits) {
              o.cur = lerp(o.cur, sy * o.depth, 0.07);
              o.el.style.translate = '0 ' + o.cur.toFixed(2) + 'px';
            }
            raf = requestAnimationFrame(tick);
          };

          // only animate while the hero is on screen (saves CPU otherwise)
          const io = new IntersectionObserver(([e]) => {
            if (e.isIntersecting) { if (!raf) raf = requestAnimationFrame(tick); }
            else if (raf) { cancelAnimationFrame(raf); raf = 0; }
          }, { threshold: 0 });
          io.observe(hero);

          addEventListener('scroll', onScroll, { passive: true });
          onScroll();
        })();
      </script>
    </header>

    <!-- WORK -->
    <section id="work">
      <div class="wrap">
        <div class="eyebrow">selected work</div>
        <h2 class="section-title">Things I've shipped</h2>
        <p class="section-sub">
          Production systems across e-commerce, sync tooling, and browser extensions —
          most serving real merchants at scale.
        </p>

        <div class="projects-grid featured-grid">
          {featured.map((p, i) => (
            <article class={`card${i === 0 ? ' big' : ''}`}>
              {p.image && (
                <div class="card-thumb">
                  <img src={p.image} alt={`${p.name} preview`} loading="lazy" width="1200" height="675" />
                </div>
              )}
              <div class="card-head">
                <h3>{p.name}</h3>
                <span class="year">{p.year}</span>
              </div>
              <p class="tagline">{p.tagline}</p>
              <div class="role">{p.role}</div>
              <p class="desc">{p.description}</p>
              <ul class="highlights">
                {p.highlights.map((h) => <li>{h}</li>)}
              </ul>
              <div class="card-stack">
                {p.stack.map((s) => <span class="tag">{s}</span>)}
              </div>
              <div class="card-links">
                {p.caseStudyUrl && (
                  <a class="card-link" href={p.caseStudyUrl}>
                    Read the case study →
                  </a>
                )}
                {p.link && (
                  <a class="card-link muted" href={p.link.url} target="_blank" rel="noopener">
                    {p.link.label} ↗
                  </a>
                )}
              </div>
            </article>
          ))}
        </div>

        <div class="projects-grid featured-grid" style="margin-top:20px;">
          {others.map((p) => (
            <article class="card">
              {p.image && (
                <div class="card-thumb">
                  <img src={p.image} alt={`${p.name} preview`} loading="lazy" width="1200" height="675" />
                </div>
              )}
              <div class="card-head">
                <h3>{p.name}</h3>
                <span class="year">{p.year}</span>
              </div>
              <p class="tagline">{p.tagline}</p>
              <div class="role">{p.role}</div>
              <p class="desc">{p.description}</p>
              <ul class="highlights">
                {p.highlights.map((h) => <li>{h}</li>)}
              </ul>
              <div class="card-stack">
                {p.stack.map((s) => <span class="tag">{s}</span>)}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- PROOF -->
    <section id="proof" class="proof">
      <div class="wrap">
        <div class="eyebrow">the part that matters</div>
        <h2 class="section-title">Merchants remember the support.</h2>
        <p class="section-sub">{proof.lead}</p>

        <div class="testimonials">
          {testimonials.map((t) => (
            <figure class={`quote-card ${t.kind}`}>
              <div class="q-mark">"</div>
              {t.stars && (
                <div class="stars" aria-label={`${t.stars} out of 5 stars`}>
                  {Array.from({ length: t.stars }).map(() => <span>★</span>)}
                </div>
              )}
              <blockquote>{t.quote}</blockquote>
              <figcaption>
                <span class="author">{t.author}</span>
                <span class="q-role">{t.role}</span>
              </figcaption>
            </figure>
          ))}
        </div>

        <p class="receipts-label">The receipts —</p>
        <div class="receipts">
          <figure class="receipt">
            <div class="receipt-frame">
              <div class="receipt-bar">
                <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
                <span class="receipt-title">Shopify App Store · email</span>
              </div>
              <img
                src="/proof/flexsync-review-liz.png"
                alt="Email from the Shopify App Store: a 5-star FlexSync review from lizfrydesign reading 'Super helpful app and passionate, supportive developers. They really spent time trying to solve an issue for me when they didn't have to! Thanks so much!'"
                loading="lazy"
                width="1320"
                height="2000"
              />
            </div>
            <figcaption>The 5★ review, as it landed in my inbox.</figcaption>
          </figure>

          <figure class="receipt">
            <div class="receipt-frame">
              <div class="receipt-bar">
                <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
                <span class="receipt-title">Slack · team channel</span>
              </div>
              <img
                src="/proof/flexsync-review-slack.png"
                alt="Slack message: Azizul Haque thanks the team and Badrul Alam for the support, with the same 5-star FlexSync review attached"
                loading="lazy"
                width="348"
                height="482"
              />
            </div>
            <figcaption>The team noticed too.</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section id="about">
      <div class="wrap">
        <div class="eyebrow">about</div>
        <h2 class="section-title">Self-taught, build-first</h2>
        <div class="about-grid">
          <div>
            <figure class="about-photo">
              <img src={profile.portrait} alt={`Portrait of ${profile.name}`} loading="lazy" width="800" height="800" />
            </figure>
            {profile.about.map((para) => <p>{para}</p>)}
          </div>
          <div class="skills-block">
            {Object.entries(profile.skills).map(([group, items]) => (
              <div class="skill-group">
                <div class="skill-head">{group}</div>
                <div class="chips">
                  {items.map((it) => <span class="chip">{it}</span>)}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- EXPERIENCE -->
    <section id="experience">
      <div class="wrap">
        <div class="eyebrow">career</div>
        <h2 class="section-title">Where I've worked</h2>
        <div class="timeline">
          {experience.map((e) => (
            <div class="tl-item">
              <div class="tl-head">
                <span><span class="co">{e.company}</span> <span class="role">· {e.role}</span></span>
                <span class="period">{e.period}</span>
              </div>
              <div class="tl-loc">{e.location}</div>
              <ul>
                {e.points.map((pt) => <li>{pt}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- WRITING -->
    <section id="writing">
      <div class="wrap">
        <div class="eyebrow">writing</div>
        <h2 class="section-title">I write to think</h2>
        <p class="section-sub">{writing.intro}</p>

        <div class="articles">
          {articles.map((a) => (
            <a class={`article${a.featured ? ' featured' : ''}`} href={a.url} target="_blank" rel="noopener">
              <div class="article-meta">
                <span class="art-date">{a.date}</span>
                <span class="art-sep">·</span>
                <span class="art-read">{a.readMins} min read</span>
                {a.featured && <span class="art-badge">Latest</span>}
              </div>
              <h3 class="article-title">{a.title}</h3>
              <p class="article-blurb">{a.blurb}</p>
              <div class="article-foot">
                <div class="art-tags">
                  {a.tags.map((t) => <span class="art-tag">#{t}</span>)}
                </div>
                <span class="art-arrow">Read on dev.to ↗</span>
              </div>
            </a>
          ))}
        </div>

        <a class="btn btn-ghost writing-more" href={writing.profileUrl} target="_blank" rel="noopener">
          All posts on dev.to →
        </a>
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="contact">
      <div class="wrap">
        <div class="eyebrow" style="justify-content:center;">get in touch</div>
        <h2>Let's build something.</h2>
        <p>
          Open to freelance, full-time, and interesting collaborations.
          Fastest way to reach me is email.
        </p>
        <div class="socials">
          <a class="social" href={`mailto:${profile.email}`}>✉ {profile.email}</a>
          {profile.socials.map((s) => (
            <a class="social" href={s.url} target="_blank" rel="noopener">
              {s.label} <span class="h">@{s.handle}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="wrap">
      <span>© 2026 {profile.name}</span>
      <span>Built with Astro · deployed on Cloudflare Pages</span>
    </div>
  </footer>
</Layout>
